rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Presentation Validation
    function isValidPresentation(data) {
      return data.userId is string && data.userId == request.auth.uid
          && data.title is string && data.title.size() <= 200
          && data.slides is list && data.slides.size() <= 100
          && data.createdAt is number
          && (data.theme == 'corporate' || data.theme == 'minimal' || data.theme == 'creative' || data.theme == 'academic');
    }

    match /presentations/{presentationId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidPresentation(incoming())
        && incoming().userId == request.auth.uid;
        
      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isValidPresentation(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (
          // Allow theme, title, slides updates
          incoming().diff(existing()).affectedKeys().hasOnly(['theme', 'title', 'slides', 'updatedAt'])
        );
        
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
